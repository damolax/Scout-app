# Scout v10.40.0 full verification build. Replace only values issued by your own projects.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY

# Final Vercel production URL, without trailing slash
NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app

# Google Gmail OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET

# Sender ceiling
SCOUT_DEPLOYMENT_DAILY_CAP=250
SCOUT_DEPLOYMENT_RUN_CAP=50

# Generate one long random value and use the same value in Vercel and Supabase Vault.
SCHEDULE_WORKER_SECRET=YOUR_ONE_LONG_RANDOM_SECRET
CRON_SECRET=YOUR_ONE_LONG_RANDOM_SECRET

# Public identity
NEXT_PUBLIC_SUPPORT_EMAIL=YOUR_SUPPORT_EMAIL
NEXT_PUBLIC_SCOUT_BRAND_NAME=Scout by We Are Creative Builders

# Full validation features
GMAIL_SEND_ENABLED=true
GMAIL_REPLY_SYNC_ENABLED=true
GMAIL_NATIVE_SIGNATURE_SYNC_ENABLED=true
PLACEMENT_TESTS_ENABLED=false
ACCOUNT_DELETION_ENABLED=true
