NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_ONLY_ON_SERVER
NEXT_PUBLIC_BACKEND_URL=https://scout-email-finder.onrender.com
NEXT_PUBLIC_ADMIN_EMAIL=oyekunleolalekan3168@gmail.com
NEXT_PUBLIC_APP_URL=https://YOUR_SCOUT_DOMAIN

# Gmail OAuth for native /settings connect + /message send
# Add the callback below in Google Cloud OAuth Client authorized redirect URIs:
# https://YOUR_DOMAIN/api/gmail/oauth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET_ONLY_ON_SERVER
# Optional alternative if you do not use NEXT_PUBLIC_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

SCOUT_DEFAULT_WORKSPACE_ID=00000000-0000-4000-8000-000000000001

# Scout v10.35 Google verification and safety flags
# The first production submission requests gmail.send only.
GMAIL_SEND_ENABLED=true
GMAIL_REPLY_SYNC_ENABLED=false
GMAIL_NATIVE_SIGNATURE_SYNC_ENABLED=false
DELIVERABILITY_CENTER_ENABLED=true
SENDER_HEALTH_ENFORCEMENT_ENABLED=true
PLACEMENT_TESTS_ENABLED=true
TEAM_PAGINATION_ENABLED=true
ACCOUNT_DELETION_ENABLED=true

# Public verification identity
NEXT_PUBLIC_SCOUT_BRAND_NAME=Scout by We Are Creative Builders
NEXT_PUBLIC_SUPPORT_EMAIL=support@YOUR_DOMAIN

# Scout v10.35.1 Scale Guard
# Central schedule execution. Set the same strong secret in Vercel and the required Render Background Worker.
SCHEDULE_WORKER_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Initial safe production capacity. These are platform controls, not user-facing limits.
SCOUT_MAX_ACTIVE_CAMPAIGNS=12
SCOUT_MAX_ACTIVE_CAMPAIGNS_PER_WORKSPACE=1
SCOUT_MAX_ACTIVE_SENDER_LANES=12
SCOUT_MAX_ACTIVE_SENDER_LANES_PER_WORKSPACE=2
SCOUT_SENDER_PAGE_SIZE=25

# Browser background polling is intentionally off. The central worker runs schedules.
NEXT_PUBLIC_CENTRAL_WORKER_ENABLED=true

# Required: set these on the Render Background Worker created from the Scout-app repository.
SCOUT_APP_URL=https://YOUR_SCOUT_DOMAIN
SCOUT_WORKER_INTERVAL_MS=10000
SCOUT_WORKER_CAMPAIGNS_PER_TICK=6
SCOUT_WORKER_MAX_BACKOFF_MS=60000

# Hidden by default for simpler Google-verification-ready onboarding.
# Set true only for private development/testing that needs raw token entry.
NEXT_PUBLIC_MANUAL_GMAIL_TOKEN_ENTRY_ENABLED=false
